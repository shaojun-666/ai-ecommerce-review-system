# Database
DATABASE_URL=postgresql://ecommerce:ecommerce_password@postgres:5432/ecommerce_reviews

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_PUBLIC_KEY_PATH=
JWT_PRIVATE_KEY_PATH=
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-random-flask-secret

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# NLP Model
NLP_MODEL_PATH=/app/nlp/models
NLP_MODEL_TYPE=bert
NLP_BERT_MODEL_NAME=bert-base-chinese
NLP_LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B
NLP_USE_GPU=true
NLP_BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO
LOG_DIR=/var/log/app
